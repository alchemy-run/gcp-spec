            "$ref": "ModifyAckDeadlineRequest"
          },
          "path": "v1beta1a/subscriptions/modifyAckDeadline",
          "httpMethod": "POST",
          "description": "Modifies the Ack deadline for a message received from a pull request."
        }
      }
