          "flatPath": "v1beta1a/subscriptions/acknowledge",
          "response": {
            "$ref": "Empty"
          },
          "path": "v1beta1a/subscriptions/acknowledge",
          "id": "pubsub.subscriptions.acknowledge"
        }
      }
