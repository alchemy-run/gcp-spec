                    "multipart": true,
                    "path": "/resumable/upload/playcustomapp/v1/accounts/{account}/customApps"
                  },
                  "simple": {
                    "multipart": true,
                    "path": "/upload/playcustomapp/v1/accounts/{account}/customApps"
                  }
                },
                "maxSize": "10737418240"
              }
            }
          }
        }
