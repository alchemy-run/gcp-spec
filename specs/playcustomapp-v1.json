              "httpMethod": "POST",
              "supportsMediaUpload": true,
              "description": "Creates a new custom app.",
              "id": "playcustomapp.accounts.customApps.create",
              "response": {
                "$ref": "CustomApp"
              },
              "parameterOrder": [
                "account"
              ],
              "scopes": [
                "https://www.googleapis.com/auth/androidpublisher"
              ],
              "parameters": {
                "account": {
                  "location": "path",
